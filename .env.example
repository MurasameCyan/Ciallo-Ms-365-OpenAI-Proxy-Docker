# M365 Copilot Access Token（首次可留空，容器启动后通过 Chrome headless 自动捕获）
M365_ACCESS_TOKEN=

# 时区（可选，默认 Asia/Tokyo）
M365_TIME_ZONE=Asia/Tokyo

# 模型别名（可选，默认 m365-copilot）
M365_MODEL_ALIAS=m365-copilot

# 是否启用自动刷新 Token（默认 true）
AUTO_REFRESH=true

# Token 过期前多少秒开始刷新（默认 300 = 5分钟）
REFRESH_BEFORE_SECONDS=300

# Chrome CDP 端口（默认 9222）
CHROME_CDP_PORT=9222
